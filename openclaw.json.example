{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true
    },
    "auth": {
      "mode": "token",
      "token": "CHANGE_ME_random_secret_token"
    }
  },
  "env": {
    "GEMINI_API_KEY": "CHANGE_ME_your_gemini_api_key"
  },
  "models": {
    "mode": "merge",
    "providers": {
      "google": {
        "baseUrl": "https://generativelanguage.googleapis.com/v1beta",
        "models": [
          {
            "id": "gemini-3-flash-preview",
            "name": "gemini-3-flash-preview",
            "reasoning": true,
            "contextWindow": 1048576,
            "maxTokens": 65536
          },
          {
            "id": "gemini-3-pro-preview",
            "name": "gemini-3-pro-preview",
            "reasoning": true,
            "contextWindow": 1048576,
            "maxTokens": 65536
          },
          {
            "id": "gemma-4-31b-it",
            "name": "Gemma 4 31B",
            "api": "google-generative-ai",
            "reasoning": true,
            "contextWindow": 262144,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "google/gemma-4-31b-it",
        "fallbacks": ["google/gemini-3-pro-preview"]
      },
      "thinkingDefault": "medium",
      "subagents": {
        "model": "google/gemma-4-31b-it"
      },
      "models": {
        "google/gemini-3-pro-preview": {
          "params": {
            "maxTokens": 65536
          }
        },
        "google/gemini-3-flash-preview": {
          "params": {
            "maxTokens": 65536
          }
        },
        "google/gemma-4-31b-it": {
          "params": {
            "maxTokens": 8192
          }
        }
      }
    }
  },
  "memory": {
    "backend": "qmd",
    "citations": "auto",
    "qmd": {
      "includeDefaultMemory": true,
      "searchMode": "search",
      "update": { "interval": "5m", "onBoot": true, "waitForBootSync": false },
      "limits": { "maxResults": 8, "timeoutMs": 5000 },
      "scope": {
        "default": "deny",
        "rules": [
          { "action": "allow", "match": { "chatType": "direct" } }
        ]
      },
      "paths": [
        { "name": "wiki", "path": "/home/node/.openclaw/workspace/wiki", "pattern": "**/*.md" }
      ]
    }
  },
  "channels": {
    "mattermost": {
      "enabled": true,
      "botToken": "CHANGE_ME_your_mattermost_bot_token",
      "baseUrl": "https://CHANGE_ME_your-mattermost-server.example.com",
      "dmPolicy": "open",
      "allowFrom": ["*"],
      "chatmode": "onmessage"
    }
  },
  "plugins": {
    "entries": {
      "mattermost": {
        "enabled": true
      }
    }
  }
}
